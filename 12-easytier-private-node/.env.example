TZ=Asia/Shanghai

# Web 控制台端口
WEB_PORT=11211

# Config server 端口（easytier-core 连接 web 控制台用）
CONFIG_SERVER_PORT=22020

# easytier-core 接入 web 控制台地址，格式：udp://127.0.0.1:22020/<用户名>
CONFIG_SERVER=udp://127.0.0.1:22020/CHANGE_ME_USERNAME

# Cloudflare Tunnel token
# 在 Cloudflare Zero Trust → Networks → Tunnels → Create tunnel → 复制 token
CF_TUNNEL_TOKEN=CHANGE_ME_TUNNEL_TOKEN
